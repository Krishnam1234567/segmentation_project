# LexOS — Backend Environment Variables
# Copy to .env and fill in production values

# ── PostgreSQL ────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=lexos
POSTGRES_PASSWORD=lexos_secret
POSTGRES_DB=lexos_db

# ── Neo4j ─────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=lexos_graph_secret

# ── ChromaDB ──────────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8000
